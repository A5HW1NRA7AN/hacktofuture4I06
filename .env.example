# --- Node 2 (Webhook & Proxy) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=

# --- Shared (all nodes) ---
LIVEKIT_URL=wss://<your-livekit-server>
LIVEKIT_API_KEY=
