# --- Node 1 (Agent & LLM) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
OLLAMA_NUM_CTX=4096

# --- Node 3 (Knowledge Base) ---
ELASTICSEARCH_HOST=localhost:9200
QDRANT_HOST=localhost:6333
